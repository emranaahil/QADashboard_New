{
  "name": "website-keyword-auditor",
  "version": "1.0.0",
  "description": "Professional Website Content Validation Tool - Crawls websites and generates PDF reports",
  "main": "backend/server.js",
  "scripts": {
    "start": "node scripts/start-production.js",
    "start:api": "node backend/server.js",
    "dev": "concurrently -n api,web -c blue,green \"nodemon --config nodemon.json backend/server.js\" \"npm run dev --prefix web\"",
    "dev:api": "nodemon --config nodemon.json backend/server.js",
    "dev:web": "npm run dev --prefix web",
    "dev:all": "npm run dev",
    "build:web": "npm run build --prefix web",
    "playwright": "npx playwright install chromium",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "keyword",
    "auditor",
    "crawler",
    "website",
    "seo",
    "pdf"
  ],
  "author": "Md Imran",
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pdfkit": "^0.14.0",
    "playwright": "1.61.0"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
