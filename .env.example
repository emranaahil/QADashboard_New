# Development
NODE_ENV=development
PORT=3000
WEB_APP_URL=http://localhost:3001

# Production (Render / Docker)
# PORT=10000          # public Next.js UI port
# API_PORT=3000       # internal Express API port
# API_URL=http://127.0.0.1:3000

# Playwright (Docker / Render — browsers pre-installed in image)
PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=true
PLAYWRIGHT_CHROMIUM_SANDBOX=false

# Persistent data (Render disk / Docker volume mount)
STORAGE_ROOT=/app/data

# Job queue — cancel stale jobs on deploy restart (recommended for production)
JOB_RECOVER_ON_STARTUP=false